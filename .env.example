# 🔑 API Keys for LangChain Series
# Rename this file to .env and replace the placeholder values with your actual API keys.

# OpenAI API Key
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY="YOUR_OPENAI_API_KEY"

# Hugging Face API Token (optional)
# Get from: https://huggingface.co/settings/tokens
HUGGINGFACEHUB_API_TOKEN="YOUR_HUGGINGFACEHUB_API_TOKEN"

# LangSmith API Key (optional, for tracing and debugging)
# Get from: https://smith.langchain.com/
LANGCHAIN_API_KEY="YOUR_LANGCHAIN_API_KEY"

# --- LangSmith Configuration ---
# Set to "true" to enable tracing
LANGCHAIN_TRACING_V2="true"
# Optional: Name your project to organize runs
LANGCHAIN_PROJECT="LangChain Series Project"
